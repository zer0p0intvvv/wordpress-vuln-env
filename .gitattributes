# Force LF for shell scripts and Dockerfiles — prevents Windows git from converting to CRLF
# which would cause "bad interpreter: ^M" errors inside Linux containers
*.sh        text eol=lf
Dockerfile  text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.toml      text eol=lf
*.json      text eol=lf
*.md        text eol=lf
